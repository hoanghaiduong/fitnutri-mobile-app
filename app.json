{
  "expo": {
    "name": "Mobile App",
    "slug": "mobile-app",
    "scheme": "mobile-app",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Cho phép $(PRODUCT_NAME) sử dụng Face ID."
        }
      ],
     [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo-google-fonts/inter/Inter_400Regular.ttf",
            "./node_modules/@expo-google-fonts/inter/Inter_500Medium.ttf",
            "./node_modules/@expo-google-fonts/inter/Inter_600SemiBold.ttf",
            "./node_modules/@expo-google-fonts/inter/Inter_700Bold.ttf"
          ]
        }
      ]
    ],
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#101828"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
