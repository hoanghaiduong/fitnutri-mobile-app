{
  "expo": {
    "name": "Mobile App",
    "slug": "mobile-app",
    "scheme": "mobile-app",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Cho phép $(PRODUCT_NAME) sử dụng Face ID."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo-google-fonts/inter/400Regular/Inter_400Regular.ttf",
            "./node_modules/@expo-google-fonts/inter/500Medium/Inter_500Medium.ttf",
            "./node_modules/@expo-google-fonts/inter/600SemiBold/Inter_600SemiBold.ttf",
            "./node_modules/@expo-google-fonts/inter/700Bold/Inter_700Bold.ttf"
          ]
        }
      ],
      "expo-secure-store"
    ],
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Cho phép $(PRODUCT_NAME) sử dụng Face ID để mở khóa nhanh.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.hoanghaiduong17112002.mobileapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#101828"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "package": "com.hoanghaiduong17112002.mobileapp"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "43121ccd-1536-48e6-9a2d-fe3ad71f6c21"
      }
    }
  }
}
